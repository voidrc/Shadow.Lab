      "titleText": "Return-Oriented Programming (ROP)",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Used when NX is enabled (can't execute shellcode on stack).",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# Find gadgets\nROPgadget --binary binary\nROPgadget --binary binary --rop\n\n# Useful gadgets\n# pop rdi ; ret     → set first argument\n# pop rsi ; ret     → set second argument\n# pop rdx ; ret     → set third argument\n# ret               → stack alignment (needed for movaps in libc)",
      "codeLang": "bash",
      "imageUrl": "",
