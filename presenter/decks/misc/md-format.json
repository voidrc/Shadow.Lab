      "bodySize": 22,
      "bullets": [
        "Use - or * for bullets. Nested lists are flattened.",
        "Keep bullets short — they render as single lines on the slide.",
        "Each ## H2 section gets its own set of bullets. Don't mix unrelated lists under one heading."
      ],
