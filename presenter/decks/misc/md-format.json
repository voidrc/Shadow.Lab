      "subtitleColor": "#2a6b3a",
      "bodyText": "Each .md file becomes one deck. Slides are generated from the heading structure:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [
          "Markdown element",
          "→ Slide result"
        ],
        "rows": [
          [
            "# H1",
            "Title card slide (centered, large, zoom transition)"
          ],
          [
            "## H2",
            "Section slide (title at top, content below)"
          ],
          [
            "### H3",
            "Treated as a sub-header bullet on the current slide"
          ],
          [
            "`code`",
            "Standalone code slide (dark bg, neon green mono text)"
          ],
          [
            "- item / * item",
            "Bullet points on the current section slide"
          ],
          [
            "`\\",
            "table \\",
            "`",
            "Each row → one bullet (col1  ::  col2  ::  col3)"
          ],
          [
            "> blockquote",
            "Subtitle text on the current slide"
          ],
          [
            "Plain paragraph",
            "Body text on the current slide"
          ]
        ]
      },
