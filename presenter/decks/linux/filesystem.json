      "titleText": "Tree Structure",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "~ is a shortcut for the current user's home directory (/home/<username>).",
      "subtitleColor": "#2a6b3a",
      "bodyText": "The filesystem starts at the root directory /. All other directories branch out from it:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "/\n├── bin\n├── etc\n├── home\n│   └── user\n├── var\n└── usr",
