      "bgImage": "",
      "titleText": "\"Folder\" vs \"Directory\"",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "They are interchangeable in meaning.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Directory — the traditional UNIX/Linux term, used in the terminal.",
        "Folder — a GUI term referring to the same concept."
      ],
