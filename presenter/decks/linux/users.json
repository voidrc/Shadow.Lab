      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Switching Users",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "The - in su - loads the target user's full environment (profile, PATH, etc.). Without it you keep the calling user's environment.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Command  ::  What it does",
        "su -  ::  Switch to root (full login shell)",
        "su <username>  ::  Switch to another user",
        "sudo -u <username> <command>  ::  Run one command as another user",
        "whoami  ::  Print the current user"
      ],
      "codeText": "",
      "codeLang": "",
