      "bgImage": "",
      "titleText": "sudo — Temporary Elevation",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "sudo (superuser do) runs a single command with elevated privileges without switching fully to the root account. Every action is logged.\nConfiguration lives in /etc/sudoers. Always edit it with visudo — it validates syntax before saving:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo apt update\nsudo systemctl restart sshd",
      "codeLang": "bash",
      "imageUrl": "",
