      "titleText": "Users & Root",
      "titleColor": "#00ff41",
      "titleSize": 52,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Linux has two categories of users: root (superuser) and normal users. Knowing the difference is essential for permissions, security, and daily operations.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
