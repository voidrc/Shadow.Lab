      "bgImage": "",
      "titleText": "User Types at a Glance",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "Root is powerful but risky — a single mistake can break the system. Operate as a normal user for daily tasks and only escalate when necessary.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "User Type  ::  Home Directory  ::  UID  ::  Privileges  ::  Common Groups",
        "root  ::  /root  ::  0  ::  Full, unrestricted  ::  root, wheel, sudo",
        "Normal user  ::  /home/<username>  ::  ≥ 1000  ::  Limited to owned files  ::  users, sudo (if granted)"
      ],
      "codeText": "",
      "codeLang": "",
