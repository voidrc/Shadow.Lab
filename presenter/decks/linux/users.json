      "bgImage": "",
      "titleText": "Root Access Groups",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Different distributions use different group names for granting sudo access:\nUsers added to one of these groups can run administrative commands via sudo.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Group  ::  Used on",
        "sudo  ::  Ubuntu, Debian",
        "wheel  ::  Fedora, CentOS, RHEL, Arch"
      ],
      "codeText": "",
      "codeLang": "",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
