      "bgImage": "",
      "titleText": "ripgrep-all (rga) — search inside anything",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "rga extends ripgrep to search inside PDFs, archives, Office docs, and more.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "rga \"password\" .            # search current directory recursively\nrga \"TODO\" src/             # search a specific path\nrga -i \"error\" logs/        # case-insensitive\nrga --type pdf \"keyword\"    # search only PDF files",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
