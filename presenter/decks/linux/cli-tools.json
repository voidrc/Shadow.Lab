      "bgImage": "",
      "titleText": "eza — better ls",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "Suggested aliases:",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Modern ls replacement with colours, icons, and git status.\n>",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "eza -la                # long list, all files\neza --tree             # directory tree\neza -la --git          # show git status per file\neza --icons -la        # file-type icons (requires a Nerd Font)",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": true,
