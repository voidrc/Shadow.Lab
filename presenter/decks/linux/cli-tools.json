      "titleText": "bat — better cat",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "Drop-in replacement for cat. Add alias cat=bat to your shell config.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Syntax-highlighted file viewer with line numbers, git diff markers, and automatic paging.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "bat file.py\nbat --plain file.txt   # no decorations\nbat -A file            # show non-printable characters",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
