    {
      "id": "13f5fabf-eca9-4fbb-aeaf-cad9d8dd5c5b",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Create",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "touch file.txt          # create empty file (or update timestamps)\nmkdir dir               # create directory\nmkdir -v dir            # verbose\nmkdir -p parent/child   # create parent directories as needed\nmkdir dir1 dir2 dir3    # create multiple at once",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "24b8e880-0f81-4f91-a6f3-f90d33ad52ef",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Copy",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "cp file1 file2          # copy file1 to file2 (overwrites if file2 exists)\ncp -v file1 file2       # verbose\ncp -i file1 file2       # prompt before overwrite\ncp -r dir1 dir2         # recursive (copy directory)\ncp -p file1 file2       # preserve ownership and timestamps\ncp file1 file2 dest/    # copy multiple files to a destination",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "6fe11b3b-e797-4d79-9322-2ab8c93f0575",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Move & Rename",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "mv file1 file2          # rename file1 to file2\nmv file dir/            # move file into directory\nmv -i file1 file2       # prompt before overwrite\nmv -n file1 file2       # never overwrite (abort silently)",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "cc6ad748-4c22-4e39-a319-cdf848293fd5",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Remove",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "There is no trash bin in Linux. Files removed from the terminal are gone.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "rm file                 # delete file\nrm -i file              # prompt before deleting\nrm -v file              # verbose\nrm -r dir               # recursive (delete directory and contents)\nrm -f file              # force (no prompt, no error if missing)",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "b1181b8d-0fa1-4f5f-a443-a15fe284bae5",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Secure Delete",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "Even shred may not fully protect secrets on SSDs or copy-on-write filesystems. Keep truly sensitive files encrypted. See GPG.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "rm only unlinks a file — the data remains on disk until overwritten. Use shred for sensitive files:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Flag  ::  Meaning",
        "-v  ::  Verbose",
        "-u  ::  Remove the file after overwriting",
        "-n 100  ::  Overwrite 100 times"
      ],
      "codeText": "shred -vu -n 100 file",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": true,
      "showBullets": true,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
