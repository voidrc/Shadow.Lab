      "transition": "fade"
    },
    {
      "id": "ef690ec7-360b-4fcc-ad1b-d5448d20cca5",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Copy",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "cp file1 file2          # copy file1 to file2 (overwrites if file2 exists)\ncp -v file1 file2       # verbose\ncp -i file1 file2       # prompt before overwrite\ncp -r dir1 dir2         # recursive (copy directory)\ncp -p file1 file2       # preserve ownership and timestamps\ncp file1 file2 dest/    # copy multiple files to a destination",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "bf8ec738-de84-436b-9eae-5a532f7e18b3",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Move & Rename",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "mv file1 file2          # rename file1 to file2\nmv file dir/            # move file into directory\nmv -i file1 file2       # prompt before overwrite\nmv -n file1 file2       # never overwrite (abort silently)",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "b3a5f456-d62f-4a4d-bb2c-caf4d5b36b4e",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Remove",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "There is no trash bin in Linux. Files removed from the terminal are gone.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "rm file                 # delete file\nrm -i file              # prompt before deleting\nrm -v file              # verbose\nrm -r dir               # recursive (delete directory and contents)\nrm -f file              # force (no prompt, no error if missing)",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "e98f1142-bee6-45df-b1a9-5e4f363b0550",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Secure Delete",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "Even shred may not fully protect secrets on SSDs or copy-on-write filesystems. Keep truly sensitive files encrypted. See GPG.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "rm only unlinks a file — the data remains on disk until overwritten. Use shred for sensitive files:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Flag  ::  Meaning",
        "-v  ::  Verbose",
        "-u  ::  Remove the file after overwriting",
        "-n 100  ::  Overwrite 100 times"
      ],
      "codeText": "shred -vu -n 100 file",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": true,
      "showBullets": true,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
