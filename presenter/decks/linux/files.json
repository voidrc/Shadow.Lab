    {
      "id": "14d5b2e2-f47d-4f1a-b939-be40e4f24ebb",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Create",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "touch file.txt          # create empty file (or update timestamps)\nmkdir dir               # create directory\nmkdir -v dir            # verbose\nmkdir -p parent/child   # create parent directories as needed\nmkdir dir1 dir2 dir3    # create multiple at once",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
