    },
    {
      "id": "eb904ba2-8580-4945-935a-fbc551d100a6",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "ls -F Symbols",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Symbol  ::  Type",
        "/  ::  Directory",
        "@  ::  Symbolic link",
        "*  ::  Executable",
        "=  ::  Socket",
        "`\\  ::  `  ::  Named pipe"
      ],
      "codeText": "",
      "codeLang": "",
      "imageUrl": "",
