      "transition": "slide-r"
    },
    {
      "id": "b8f4640f-b7af-4bfe-a644-663d08ff5cb5",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "ls -F Symbols",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Symbol  ::  Type",
        "/  ::  Directory",
        "@  ::  Symbolic link",
        "*  ::  Executable",
        "=  ::  Socket",
        "`\\  ::  `  ::  Named pipe"
      ],
      "codeText": "",
      "codeLang": "",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
