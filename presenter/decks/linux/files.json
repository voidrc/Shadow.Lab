      "bgImage": "",
      "titleText": "Timestamps",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Every file tracks three timestamps:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Timestamp  ::  Abbrev  ::  Updated when...",
        "Access time  ::  atime  ::  The file is read",
        "Modified time  ::  mtime  ::  The file's content changes",
        "Changed time  ::  ctime  ::  File metadata changes (permissions, ownership, links)"
      ],
      "codeText": "",
      "codeLang": "",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": true,
      "showCode": false,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "bcb858ca-9f8c-4c00-bc5a-706cd39d2ab7",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Viewing Timestamps",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "stat file          # full timestamp details\nls -l              # standard listing (mtime)\nls -lt             # sort by mtime\nls -lu             # show atime\nls -ltu            # sort by atime\nls -lc             # show and sort by ctime\nls --full-time     # full timestamp format (ls may abbreviate)",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "cdc67201-2311-4c23-866f-00d3aa758741",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Changing Timestamps with touch",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "ctime cannot be set directly — it updates automatically whenever metadata changes.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "touch updates timestamps. If the file doesn't exist, it creates it.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "touch file                        # update atime and mtime to now\ntouch -a file                     # update atime only\ntouch -m file                     # update mtime only\ntouch -m -t 20251022110000 file   # set mtime to a specific time\ntouch -d \"2025-10-22 11:00:00\" file\ntouch target -r reference         # copy timestamps from another file",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "ac852f2e-002f-4d70-b02b-881d33c5458d",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "File Types",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Linux identifies files by their content headers, not their extension. Renaming video.mp4 to video.txt doesn't change what the file actually is.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "file photo.jpg        # identify a single file\nfile /etc/*           # identify every file in a directory",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "da340c15-0129-4aef-aa18-ed9b7012bd3a",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Type Indicators in ls -l",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "The first character of each line shows the file type:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Character  ::  Type",
        "-  ::  Regular file",
        "d  ::  Directory",
        "l  ::  Symbolic link",
        "b  ::  Block device",
        "c  ::  Character device",
        "s  ::  Socket",
        "p  ::  Named pipe (FIFO)"
      ],
      "codeText": "",
      "codeLang": "",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": true,
      "showCode": false,
