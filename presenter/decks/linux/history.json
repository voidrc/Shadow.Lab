      "bgImage": "",
      "titleText": "Controlling What Gets Saved",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Prefix a command with a space to stop it from being recorded:\nThis behavior is controlled by HISTCONTROL:\nSet it in your shell config (e.g. ~/.zshrc or ~/.bashrc):",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [
          "Value",
          "Effect"
        ],
        "rows": [
          [
            "ignorespace",
            "Skip commands prefixed with a space"
          ],
          [
            "ignoredups",
            "Skip consecutive duplicate commands"
          ],
          [
            "ignoreboth",
            "Both of the above"
          ]
        ]
      },
      "codeText": "secret-command --password=hunter2",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
