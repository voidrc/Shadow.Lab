      "titleText": "Timestamps",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Add timestamps to every history entry so you can audit when commands were run:\nExample output:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "HISTTIMEFORMAT=\"%d/%m/%Y %T \"",
      "codeLang": "bash",
