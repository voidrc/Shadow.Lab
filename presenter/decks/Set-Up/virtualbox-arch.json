    {
      "id": "5f1db162-2e29-4a0e-9ca0-49293719a638",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Step 5 — Extension Pack (Optional)",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Adds USB 2/3, RDP, NVMe, and disk encryption support.\nDownload the pack matching your VirtualBox version from the official downloads page, then install:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "sudo VBoxManage extpack install Oracle_VirtualBox_Extension_Pack*.vbox-extpack",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
