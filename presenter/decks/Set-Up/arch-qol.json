    {
      "id": "3a6c871e-c895-4584-9662-91aaf9e87806",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Tokyo Night Theme (Manual)",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "Requires a Nerd Font installed (e.g., JetBrainsMono Nerd Font) for icons to render correctly.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Add to ~/.config/nvim/lua/plugins/colorscheme.lua:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "return {\n  {\n    \"folke/tokyonight.nvim\",\n    lazy = false,\n    priority = 1000,\n    opts = {\n      style = \"storm\", -- \"night\", \"day\", or \"storm\" (best for Hyprland)\n      transparent = true, -- required for Hyprland blur\n      styles = {\n        comments = { italic = true },\n        keywords = { italic = true },\n        functions = {},\n        variables = {},\n      },\n      day_brightness = 0.3,\n      dim_inactive = false,\n      lualine_bold = false,\n      on_highlights = function(hl, c)\n        hl.CursorLine = { bg = \"#24283b\" }\n      end,\n    },\n    config = function(_, opts)\n      require(\"tokyonight\").setup(opts)\n      vim.cmd.colorscheme(\"tokyonight\")\n    end,\n  },\n}",
      "codeLang": "lua",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
