    {
      "id": "460f2f9d-05ef-4529-8385-ce72f2a55789",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Step 4 — Install lazydocker",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "lazydocker is a terminal UI for managing containers, images, volumes, and logs.\nVia AUR (recommended):\nVia the official install script (no AUR helper required):",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "yay -S lazydocker\n# or\nparu -S lazydocker",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "e53c27b1-c2b9-4ebd-a224-0947641c1ca2",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Step 4 — Install lazydocker",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "The binary is placed in ~/.local/bin/lazydocker. Make sure ~/.local/bin is in your $PATH.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "curl https://raw.githubusercontent.com/jesseduffield/lazydocker/master/scripts/install_update_linux.sh | bash",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "bc0e45d3-601a-4cfc-a2ee-680fc862dff8",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Step 5 — Launch lazydocker",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Or alias it for convenience:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "lazydocker",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "8c76a42c-b041-4e29-83ef-6666bb19d71b",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Step 5 — Launch lazydocker",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "echo \"alias lzd='lazydocker'\" >> ~/.zshrc\nsource ~/.zshrc",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showTable": false,
