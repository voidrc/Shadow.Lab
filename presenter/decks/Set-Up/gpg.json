          [
            "Key size",
            "4096"
          ],
          [
            "Expiration",
            "0 (never)"
          ],
          [
            "Name / Email",
            "your alias"
          ],
          [
            "Passphrase",
            "strong and memorized"
          ]
        ]
      },
      "codeText": "gpg --full-generate-key",
