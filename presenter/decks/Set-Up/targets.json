    {
      "id": "968d47e2-4e18-462c-8079-e8a38792d4f8",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "VulnHub (local VMs)",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "VulnHub hosts downloadable VM images, not Docker containers. Download an image, import it into VirtualBox or QEMU, and attack it from your Kali VM on an isolated network.\nvulnhub.com",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
