      "bgImage": "",
      "titleText": "Metasploitable 2",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "Bind only to loopback or an isolated network — never expose this to a real network.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "A deliberately vulnerable Linux VM exposed as a network target. Covers services like FTP, SSH, Samba, MySQL, Tomcat, and more.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "docker run -d -p 22:22 -p 80:80 -p 445:445 tleemcjr/metasploitable2",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
