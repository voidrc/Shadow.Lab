    {
      "id": "b44d568e-0b9a-4a91-b05a-06b79790b22e",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Docker Bench for Security",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Runs the CIS Docker Benchmark checks against your host and running containers. Use it to audit your setup before deploying anything real.\nGitHub",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "docker run --rm --net host --pid host --userns host --cap-add audit_control \\\n  -e DOCKER_CONTENT_TRUST=$DOCKER_CONTENT_TRUST \\\n  -v /etc:/etc:ro \\\n  -v /lib/systemd/system:/lib/systemd/system:ro \\\n  -v /usr/bin/containerd:/usr/bin/containerd:ro \\\n  -v /usr/bin/runc:/usr/bin/runc:ro \\\n  -v /usr/lib/systemd:/usr/lib/systemd:ro \\\n  -v /var/lib:/var/lib:ro \\\n  -v /var/run/docker.sock:/var/run/docker.sock:ro \\\n  --label docker_bench_security \\\n  docker/docker-bench-security",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
