    {
      "id": "d9a21bc8-8f8a-465b-98c7-e417fbc04d8e",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Kubernetes Goat",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "An intentionally vulnerable Kubernetes cluster. Covers misconfigurations, RBAC weaknesses, secret exposure, and container breakouts.\nGitHub",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "git clone https://github.com/madhuakula/kubernetes-goat\ncd kubernetes-goat\nbash setup-kubernetes-goat.sh",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
