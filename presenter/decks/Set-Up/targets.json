    {
      "id": "3478ac53-92d3-4b45-aeda-47fc6582e8b4",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Damn Vulnerable Docker (DVD)",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "A deliberately misconfigured Docker environment to practice container escapes, privilege escalation inside containers, and Docker daemon abuse.\nGitHub",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "git clone https://github.com/christophetd/damn-vulnerable-docker\ncd damn-vulnerable-docker\ndocker compose up -d",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
