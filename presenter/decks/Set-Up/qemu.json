      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "What is QEMU/KVM?",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "Commands here target Arch and Arch-based distros. Other distros may have different package names.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "QEMU/KVM is a virtualization stack built into the Linux kernel.\nCompared to VirtualBox:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [
          "QEMU/KVM"
        ],
        "rows": [
          [
            "Performance",
            "Runs closer to native speed via hardware virtualization"
          ],
          [
            "Control",
            "Networking, snapshots, and storage are configurable at a low level"
          ],
          [
            "Interface",
            "CLI-first — managed with virsh and virt-install"
          ]
        ]
      },
      "codeText": "",
      "codeLang": "",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": true,
      "showBullets": false,
      "showTable": true,
      "showCode": false,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "db646a06-b7d6-4ccc-90be-e25e05f4881f",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Step 1 — Install the Virtualization Stack",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [
          "Package",
          "Purpose"
        ],
        "rows": [
          [
            "qemu-full",
            "Emulator/hypervisor core"
          ],
          [
            "virt-manager",
            "GUI frontend for managing VMs"
          ],
          [
            "libvirt",
            "Daemon that manages virtualization resources"
          ],
          [
            "dnsmasq",
            "DHCP and DNS for virtual networks"
          ],
          [
            "iptables-nft",
            "Firewall rules (required for NAT networking)"
          ],
          [
            "edk2-ovmf",
            "UEFI firmware support for VMs"
          ],
          [
            "virt-install",
            "CLI tool for creating VMs"
          ]
        ]
      },
      "codeText": "sudo pacman -Syu qemu-full virt-manager libvirt dnsmasq ebtables iptables-nft edk2-ovmf virt-install",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showTable": true,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "af9e113e-69b5-4b42-bee7-f153dbb60d3e",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Step 2 — Enable libvirt",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Enable and start the daemon:\nAdd your user to the libvirt group to manage VMs without sudo:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "sudo systemctl enable --now libvirtd",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "cb111832-edf6-47b8-8db0-946adec301c5",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Step 2 — Enable libvirt",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Log out and back in (or reboot) for the group change to take effect.\nVerify the daemon is running:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "sudo usermod -aG libvirt $USER",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "a38f1f4b-34f5-4d37-ace6-9b81bbd9ac93",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Step 2 — Enable libvirt",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Check available virtual networks:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "virsh --connect qemu:///system list --all",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "bf5d35e3-982f-46bd-a99a-e43b7d1566bd",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Step 2 — Enable libvirt",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
