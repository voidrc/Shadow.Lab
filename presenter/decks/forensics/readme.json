      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# Look for unusually long subdomain queries → data encoded in DNS\ntshark -r capture.pcap -Y dns.qry.type==1 -T fields -e dns.qry.name | sort -u\n\n# Decode base32/hex from subdomain labels\necho \"aGVsbG8=\" | base64 -d",
      "codeLang": "bash",
