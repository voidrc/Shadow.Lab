      "codeText": "# Read raw bytes\nwith open('file.bin', 'rb') as f:\n    data = f.read()\n\n# Find all occurrences of pattern\nimport re\nmatches = re.findall(b'flag\\{.*?\\}', data)\n\n# XOR all bytes with key\nkey = 0x42\ndecoded = bytes([b ^ key for b in data])",
