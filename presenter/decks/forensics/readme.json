      "transition": "fade"
    },
    {
      "id": "1dade3cb-d605-4b24-8b1c-6040bc97ea94",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "tshark (CLI)",
      "titleColor": "#00ff41",
      "titleSize": 36,
