    {
      "id": "f999176b-55c0-4ec1-8fc7-7af266eba7b1",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Memory Forensics (Volatility 3)",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# Install\npip install volatility3\n\n# Basic usage\npython3 vol.py -f memory.dmp <plugin>\n\n# OS detection\npython3 vol.py -f memory.dmp windows.info\npython3 vol.py -f memory.dmp linux.info\n\n# Common Windows plugins\nwindows.pslist           # running processes\nwindows.pstree           # process tree\nwindows.cmdline          # command line arguments\nwindows.filescan         # scan for file objects\nwindows.dumpfiles        # dump a file from memory\nwindows.hashdump         # dump NTLM hashes\nwindows.netscan          # network connections\nwindows.malfind          # find injected code\n\n# Dump a specific process\npython3 vol.py -f memory.dmp windows.dumpfiles --pid 1234\n\n# Search for a string in memory\npython3 vol.py -f memory.dmp windows.strings --strings-file strings.txt\nstrings memory.dmp | grep -i \"flag{\"",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "d54ffcc8-ca9a-47da-8374-5471e8536030",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Disk Image Forensics",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# Mount a raw disk image\nsudo mount -o loop,ro disk.img /mnt/forensics\n\n# List partitions\nfdisk -l disk.img\nmmls disk.img            # sleuthkit\n\n# Browse filesystem\nautopsy                  # GUI tool (starts web server)\n\n# Recover deleted files\nphotorec disk.img\ntestdisk disk.img        # recover partition table / lost files\n\n# Timeline\nfls -r -m / disk.img > bodyfile.txt\nmactime -b bodyfile.txt > timeline.txt",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
