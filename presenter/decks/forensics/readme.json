      "titleText": "Wireshark",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# Open PCAP\nwireshark capture.pcap\n\n# Useful filters\ntcp                      # only TCP\nhttp                     # HTTP traffic\nhttp.request             # HTTP requests\ndns                      # DNS queries\nip.addr == 192.168.1.1   # traffic to/from IP\ntcp.stream eq 0          # follow TCP stream 0\nframe contains \"flag\"    # search packet content\n\n# Follow a stream: Right-click packet → Follow → TCP Stream\n# Export HTTP objects: File → Export Objects → HTTP",
      "codeLang": "",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "e0c930f0-1415-484a-9e68-cebfc2ea60a2",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "tshark (CLI)",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# List all streams\ntshark -r capture.pcap -z conv,tcp\n\n# Extract HTTP URIs\ntshark -r capture.pcap -Y http.request -T fields -e http.request.uri\n\n# Extract all files via HTTP\ntshark -r capture.pcap --export-objects http,output_dir/\n\n# Decode specific stream\ntshark -r capture.pcap -q -z follow,tcp,ascii,0\n\n# Find credentials in HTTP Basic Auth\ntshark -r capture.pcap -Y 'http.authorization' -T fields -e http.authorization",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "bd3527bb-195a-4c4b-a30b-af34383c0ed4",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "DNS Exfiltration",
      "titleColor": "#00ff41",
