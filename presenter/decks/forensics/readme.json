      "transition": "fade"
    },
    {
      "id": "29f53beb-7e5d-4849-8e54-2a284f737742",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "DNS Exfiltration",
