      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# With valid credentials\n# BloodHound data collection\nbloodhound-python -u user -p 'Password123' -d target.local -dc dc01.target.local -c All\n\n# PowerView (on Windows target)\nGet-NetDomain\nGet-NetUser | select name,memberof,lastlogon\nGet-NetGroup -GroupName \"Domain Admins\"\nGet-NetComputer | select name,operatingsystem\nFind-LocalAdminAccess   # find machines where current user is local admin\nInvoke-ACLScanner       # find misconfigured ACLs\n\n# ldapdomaindump\nldapdomaindump -u 'target\\user' -p 'Password123' dc01.target.local",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
