    {
      "id": "34214564-4757-4fdb-b864-e8f3dea438db",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Passive Recon (No Contact With Target)",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# WHOIS / DNS\nwhois target.com\ndig target.com ANY +noall +answer\ndig @8.8.8.8 target.com MX\n\n# Certificate transparency\ncurl \"https://crt.sh/?q=%.target.com&output=json\" | python3 -m json.tool | grep name_value\n\n# Subdomain enumeration (passive)\nsubfinder -d target.com -o subs.txt\namass enum -passive -d target.com\n\n# Technology fingerprinting\nwhatweb https://target.com\ncurl -s https://target.com | grep -i \"generator\\|powered\\|version\"\n\n# Shodan (indexed internet assets)\nshodan search 'org:\"Target Organisation\"'\nshodan host <ip>\n\n# ASN / IP range lookup\nwhois -h whois.radb.net -- '-i origin AS12345'\n# https://bgp.he.net",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
