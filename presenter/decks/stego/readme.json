      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "LSB (Least Significant Bit) Stego",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "The most common technique: hides data in the lowest bits of pixel colour values.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# Manual LSB extraction (PNG, channel R)\nfrom PIL import Image\n\nimg = Image.open('image.png')\npixels = list(img.getdata())\n\nbits = ''\nfor pixel in pixels:\n    for channel in pixel[:3]:   # R, G, B\n        bits += str(channel & 1)\n\n# Convert bits to bytes\nchars = [chr(int(bits[i:i+8], 2)) for i in range(0, len(bits), 8)]\nprint(''.join(chars)[:100])",
      "codeLang": "python",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
