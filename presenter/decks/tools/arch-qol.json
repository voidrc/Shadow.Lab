      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Activate:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "set ipv4.method manual\nset ipv4.addresses 172.16.0.11/24\nset ipv4.gateway 172.16.0.1\nset ipv4.dns \"1.1.1.1 8.8.8.8\"\nsave\nquit",
      "codeLang": "",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
