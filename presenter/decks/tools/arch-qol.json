      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Enter the password once. The key is installed into ~/.ssh/authorized_keys on the server.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "ssh-copy-id USER@IP",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
