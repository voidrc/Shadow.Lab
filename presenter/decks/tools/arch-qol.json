      "titleText": "Usage",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "The more you use it, the smarter it gets — it learns your habits.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Command  ::  Action",
        "z <keyword>  ::  Jump to the best match for <keyword> (e.g., z proj)",
        "zi  ::  Interactive fuzzy picker (list all frequent dirs)",
        "z foo bar  ::  Jump to a dir matching both \"foo\" and \"bar\"",
        "z -i  ::  Interactive mode (manual selection)"
      ],
      "codeText": "",
      "codeLang": "",
