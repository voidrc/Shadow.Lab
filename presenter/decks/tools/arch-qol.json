      "titleText": "Quick Setup with LazyVim",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Easiest way to get a functional editor with plugins and themes pre-configured:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# Backup old config\nmv ~/.config/nvim ~/.config/nvim.bak\n# Clone LazyVim starter\ngit clone https://github.com/LazyVim/starter ~/.config/nvim\n# Remove the .git folder\nrm -rf ~/.config/nvim/.git",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
