    },
    {
      "id": "1b74b3ae-0534-4fea-a7ed-52c0ddcb0f2d",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Install and Enable",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo systemctl status sshd\nss -tlnp | grep :22",
      "codeLang": "bash",
      "imageUrl": "",
