    {
      "id": "f40f638a-94bd-47d1-b589-0e0867d5075e",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Step 5 — Extension Pack (Optional)",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Adds USB 2/3, RDP, NVMe, and disk encryption support.\nDownload the pack matching your VirtualBox version from the official downloads page, then install:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo VBoxManage extpack install Oracle_VirtualBox_Extension_Pack*.vbox-extpack",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "6c2472f3-33a1-4252-a6eb-8bdd04d4781d",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Common Arch Quirks",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
