    {
      "id": "374115a8-cc22-4bb2-98ba-23c036e6989e",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Step 5 — Extension Pack (Optional)",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Adds USB 2/3, RDP, NVMe, and disk encryption support.\nDownload the pack matching your VirtualBox version from the official downloads page, then install:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo VBoxManage extpack install Oracle_VirtualBox_Extension_Pack*.vbox-extpack",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "37f08692-dbb4-4073-b2b6-d39f862dffc6",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Common Arch Quirks",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Issue  ::  Fix",
        "Kernel mismatch after update  ::  sudo dkms autoinstall",
        "Modules blocked at boot  ::  Disable Secure Boot or sign the modules",
        "UI glitches on Wayland  ::  Launch under X11: DISPLAY=:0 virtualbox"
      ],
      "codeText": "",
