      "subtitleColor": "#2a6b3a",
      "bodyText": "Setup guide for Arch and Arch-based distros (Manjaro, EndeavourOS, CachyOS, etc.).",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "",
      "codeLang": "",
