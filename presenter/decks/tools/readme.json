    {
      "id": "4b627e74-9f1d-4387-9b1d-f4bf37ebb571",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Step 2 — Set Up a Virtual Machine",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "On Arch / Garuda / BlackArch:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "sudo apt update && sudo apt install -y virtualbox",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "f6e379d4-24b9-458b-a2bb-e66f7ca4f443",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Step 2 — Set Up a Virtual Machine",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "#### Creating your first VM (Kali Linux example)\nThat's it — Kali boots up in a window. Default login: kali / kali.\n#### Recommended settings (adjust after importing)\nRight-click your VM → Settings:\n#### Snapshots — your \"undo\" button\nBefore you install tools or start experimenting, take a snapshot. If anything goes wrong, you can roll back instantly.\nIn VirtualBox: Machine → Take Snapshot → name it clean-base.\nTo restore: Machine → Restore Snapshot → clean-base.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Download the Kali Linux VirtualBox image — pick the VirtualBox version (.ova file).",
        "Open VirtualBox → File → Import Appliance → select the .ova file → click Import.",
        "Select the new VM and click Start."
      ],
      "tableData": {
        "headers": [
          "Setting",
          "What to set",
          "Why"
        ],
        "rows": [
          [
            "System → Memory",
            "4096 MB (4 GB) or more",
            "Less than 4 GB and tools will be slow"
          ],
          [
            "System → Processors",
            "2 CPUs",
            "Keeps things responsive"
          ],
          [
            "Storage → Disk",
            "60 GB+ (dynamically allocated)",
            "Tools take up space quickly"
          ],
          [
            "Network → Adapter 1",
            "NAT",
            "Gives the VM internet access"
          ],
          [
            "General → Advanced → Clipboard",
            "Bidirectional",
            "Lets you copy/paste between VM and host"
          ]
        ]
      },
      "codeText": "sudo pacman -S virtualbox virtualbox-host-modules-arch",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": true,
      "showTable": true,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "c61d4dfb-29aa-408d-9743-543bfcbf3a6f",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Step 3 — Bare-Metal Install (Optional)",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "If you want to install Linux directly on a physical computer instead of a VM:\nThis updates all software before you start.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Download the ISO for your chosen OS.",
        "Flash it to a USB drive using Balena Etcher — just pick the ISO and your USB stick, click Flash.",
        "Reboot the computer, boot from USB (usually press F12 or F2 at startup), and follow the on-screen installer.",
        "After installation, open a terminal and run:"
      ],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "sudo apt update && sudo apt full-upgrade -y && sudo reboot",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": true,
      "showTable": false,
      "showCode": true,
