    {
      "id": "99ef2db9-cd24-43b2-98db-71c5f9e06974",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Step 2 — Set Up a Virtual Machine",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "Not sure which to pick? Use VirtualBox — it's free, runs on Windows/macOS/Linux, and has thousands of tutorials.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "A virtual machine lets you run a second operating system (like Kali Linux) as a window on your current computer. Your real system is never touched.\nPick the VM software for your computer:\n#### Installing VirtualBox\nOn Windows: Download the installer from virtualbox.org and run it like any other program.\nOn macOS:\n(If you don't have Homebrew yet: brew.sh)\nOn Ubuntu / Debian Linux:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [
          "Software",
          "Your computer runs...",
          "Cost",
          "Best for"
        ],
        "rows": [
          [
            "VirtualBox",
            "Windows, macOS, Linux",
            "Free",
            "Beginners — easiest to get started"
          ],
          [
            "VMware Workstation Pro",
            "Windows, Linux",
            "Free (personal)",
            "Slightly faster than VirtualBox"
          ],
          [
            "VMware Fusion",
            "macOS",
            "Free (personal)",
            "Mac users on Intel chips"
          ],
          [
            "Parallels Desktop",
            "macOS",
            "Paid",
            "Mac users on Apple Silicon (M1/M2/M3)"
          ],
          [
            "GNOME Boxes",
            "Linux",
            "Free",
            "Linux users who want the simplest option"
          ],
          [
            "Virt-Manager / KVM",
            "Linux",
            "Free",
            "Linux users who want maximum performance"
          ]
        ]
      },
      "codeText": "brew install --cask virtualbox",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": true,
      "showBullets": false,
      "showTable": true,
      "showCode": true,
