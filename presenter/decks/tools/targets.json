      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Over 100 web vulnerabilities in a single PHP app. Good breadth for systematically working through vulnerability classes.\nOpen http://localhost/bWAPP — default login: bee / bug",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "docker run -d -p 80:80 raesene/bwapp",
      "codeLang": "bash",
