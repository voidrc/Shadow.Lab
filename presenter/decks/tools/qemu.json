    },
    {
      "id": "c8084634-a3bf-455b-af2e-7bdd1f52184b",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Step 3 — Custom Networks (Optional)",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Two network profiles are available depending on your lab needs. You can define one or both.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "",
      "codeLang": "",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": false,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "c720da4e-67db-4d94-8bee-d9c37edbb5a3",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Option A — NAT (NAT)",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "VMs get a private internal network. Internet access is routed through the host via NAT.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo vim /tmp/NAT.xml",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "0c24fe0c-fdda-4876-8dad-3da81e82162c",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Option A — NAT (NAT)",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Setting  ::  Value",
        "Network name  ::  NAT",
        "Bridge interface  ::  virbr10",
        "Internal domain  ::  shadow_lab",
        "Gateway  ::  10.10.10.1",
        "DHCP range  ::  10.10.10.2 – 10.10.10.200"
      ],
      "codeText": "<network>\n  <name>NAT</name>\n  <forward mode='nat'/>\n  <bridge name='virbr10' stp='on' delay='0'/>\n  <domain name='shadow_lab'/>\n  <ip address='10.10.10.1' netmask='255.255.255.0'>\n    <dhcp>\n      <range start='10.10.10.2' end='10.10.10.200'/>\n    </dhcp>\n  </ip>\n</network>",
      "codeLang": "xml",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": true,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "37e45d7f-d464-4d70-b50c-4438217f33ef",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Option A — NAT (NAT)",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo virsh net-define /tmp/NAT.xml\nsudo virsh net-start NAT\nsudo virsh net-autostart NAT",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "57a6d020-462b-4dc7-a8b3-ca0b42b2e5b3",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Option B — Bridged LAN (LAN)",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "Replace eth0 with your actual host interface (ip link to check).",
      "subtitleColor": "#2a6b3a",
      "bodyText": "VMs attach directly to the physical LAN via an unmanaged switch. No DHCP is available on the network — every VM needs a static IP configured inside the guest OS.\nReserved IP range for QEMU VMs: 172.16.0.15 – 172.16.0.19\nFirst, bridge the physical interface on the host:\nTo persist across reboots, add the bridge to your network manager config (e.g. systemd-networkd or NetworkManager).\nThen define the libvirt network:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo ip link add virbr20 type bridge\nsudo ip link set eth0 master virbr20\nsudo ip link set virbr20 up",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "eddfc046-178b-42fe-b3fa-0ea032e92c7e",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Option B — Bridged LAN (LAN)",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo vim /tmp/LAN.xml",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "8e95ee7f-19cc-4a72-a17c-a917e3034f0f",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Option B — Bridged LAN (LAN)",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Setting  ::  Value",
        "Network name  ::  LAN",
        "Bridge interface  ::  virbr20",
        "Reserved range  ::  172.16.0.15 – 172.16.0.19",
        "Gateway  ::  set on your router/host"
      ],
      "codeText": "<network>\n  <name>LAN</name>\n  <forward mode='bridge'/>\n  <bridge name='virbr20'/>\n</network>",
      "codeLang": "xml",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": true,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "2b4d17a3-d740-4895-bee6-f7c962d5bcfe",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Option B — Bridged LAN (LAN)",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "#### Setting a Static IP Inside a VM\nAfter creating a VM on the LAN network, configure the static IP inside the guest. Using nmcli:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo virsh net-define /tmp/LAN.xml\nsudo virsh net-start LAN\nsudo virsh net-autostart LAN",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "d3116eb4-ccea-4813-a97e-536e1143f435",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Option B — Bridged LAN (LAN)",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Increment the last octet (172.16.0.15, .16, .17…) for each new VM. Keep a note of which IP is assigned to which VM to avoid conflicts within the reserved range.",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# Run inside the VM guest\nnmcli con mod \"Wired connection 1\" \\\n  ipv4.method manual \\\n  ipv4.addresses 172.16.0.15/24 \\\n  ipv4.gateway 172.16.0.1 \\\n  ipv4.dns \"1.1.1.1 8.8.8.8\"\nnmcli con up \"Wired connection 1\"",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "67b3e807-8c8d-4de2-8c96-278bb83fa066",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Verify",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo virsh net-list --all\nsudo virsh net-info NAT\nsudo virsh net-info LAN",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
