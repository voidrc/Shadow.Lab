      "bgImage": "",
      "titleText": "What is QEMU/KVM?",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "Commands here target Arch and Arch-based distros. Other distros may have different package names.",
      "subtitleColor": "#2a6b3a",
      "bodyText": "QEMU/KVM is a virtualization stack built into the Linux kernel.\nCompared to VirtualBox:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "QEMU/KVM",
        "Performance  ::  Runs closer to native speed via hardware virtualization",
        "Control  ::  Networking, snapshots, and storage are configurable at a low level",
        "Interface  ::  CLI-first — managed with virsh and virt-install"
      ],
      "codeText": "",
      "codeLang": "",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": true,
      "showBody": true,
      "showBullets": true,
      "showCode": false,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "c70f6101-b799-4c40-8023-ab09cae87553",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Step 1 — Install the Virtualization Stack",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Package  ::  Purpose",
        "qemu-full  ::  Emulator/hypervisor core",
        "virt-manager  ::  GUI frontend for managing VMs",
        "libvirt  ::  Daemon that manages virtualization resources",
        "dnsmasq  ::  DHCP and DNS for virtual networks",
        "iptables-nft  ::  Firewall rules (required for NAT networking)",
        "edk2-ovmf  ::  UEFI firmware support for VMs",
        "virt-install  ::  CLI tool for creating VMs"
      ],
      "codeText": "sudo pacman -Syu qemu-full virt-manager libvirt dnsmasq ebtables iptables-nft edk2-ovmf virt-install",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": true,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "dc4681be-b67e-42c4-9b04-5e40f838f19f",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Step 2 — Enable libvirt",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Enable and start the daemon:\nAdd your user to the libvirt group to manage VMs without sudo:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo systemctl enable --now libvirtd",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "2b072560-e0c1-47fe-b6ea-4c17d84458c0",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Step 2 — Enable libvirt",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Log out and back in (or reboot) for the group change to take effect.\nVerify the daemon is running:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo usermod -aG libvirt $USER",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "1261bf18-1df8-4f65-b696-52e99bd4688e",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Step 2 — Enable libvirt",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Check available virtual networks:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "virsh --connect qemu:///system list --all",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "a671bc2a-87be-4763-9ac3-d98dfea6db19",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Step 2 — Enable libvirt",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "virsh net-list --all",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
