      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "When prompted:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Prompt  ::  Recommended value",
        "Key type  ::  RSA and RSA (default)",
        "Key size  ::  4096",
        "Expiration  ::  0 (never)",
        "Name / Email  ::  your alias",
        "Passphrase  ::  strong and memorized"
      ],
      "codeText": "gpg --full-generate-key",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": true,
      "showCode": true,
