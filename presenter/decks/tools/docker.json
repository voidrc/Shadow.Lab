      "bgImage": "",
      "titleText": "Step 3 — Add User to docker Group",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Running Docker without sudo requires your user to be in the docker group:\nLog out and back in for the group change to take effect.\nVerify:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "sudo usermod -aG docker $USER",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showCode": true,
