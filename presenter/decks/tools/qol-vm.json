    {
      "id": "8bfb317d-4971-4ded-851b-60cb4541564e",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "GRUB Timeout",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "No need for a boot countdown inside a VM — disable it:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "sudo vim /etc/default/grub",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "0f8fc40b-b287-4fab-b987-f9b1f879bc2d",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "GRUB Timeout",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Apply the change:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "GRUB_TIMEOUT=0\nGRUB_TIMEOUT_STYLE=hidden",
      "codeLang": "ini",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "235f24c7-4f72-430f-ac81-d6264c929b56",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "GRUB Timeout",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "sudo grub-mkconfig -o /boot/grub/grub.cfg",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "feddfc93-d73b-42b4-a00c-7b0aac58c5a1",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Auto Login",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Already authenticated on the host — skip the login screen:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "sudo vim /etc/lightdm/lightdm.conf",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "3a00df6b-5820-4d08-9838-9389077197c9",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Auto Login",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Add your user to the autologin group:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "[Seat:*]\nautologin-user=<login_user>\nautologin-user-timeout=0\nautologin-session=xfce",
      "codeLang": "ini",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "a7ccd53f-6498-4637-98e4-fbf17e0f4177",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Auto Login",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "sudo groupadd -r autologin 2>/dev/null\nsudo gpasswd -a $USER autologin",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
