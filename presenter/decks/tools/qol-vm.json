      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "Host already locks — no need to double-lock inside the VM too.\nDisable the soft lock layer:",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [
        "Settings → Power Manager",
        "Settings → Xfce Screensaver"
      ],
