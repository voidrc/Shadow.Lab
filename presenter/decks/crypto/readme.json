      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Vigenère",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# Online: https://www.dcode.fr/vigenere-cipher\n# Or use CyberChef \"Vigenère Decode\"\n\n# Manual decode\ndef vigenere_decrypt(ct, key):\n    pt = []\n    key = key.upper()\n    ki = 0\n    for c in ct:\n        if c.isalpha():\n            shift = ord(key[ki % len(key)]) - ord('A')\n            base  = ord('A') if c.isupper() else ord('a')\n            pt.append(chr((ord(c) - base - shift) % 26 + base))\n            ki += 1\n        else:\n            pt.append(c)\n    return ''.join(pt)",
      "codeLang": "python",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
