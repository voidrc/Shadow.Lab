      "codeText": "# A↔Z, B↔Y, C↔X ...\ndef atbash(s):\n    return ''.join(chr(ord('Z')-(ord(c)-ord('A'))) if c.isupper()\n                   else chr(ord('z')-(ord(c)-ord('a'))) if c.islower()\n                   else c for c in s)",
