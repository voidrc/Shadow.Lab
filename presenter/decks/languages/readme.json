      "codeText": "# x86-64 execve(\"/bin/sh\", NULL, NULL)\n.section .text\n.global _start\n_start:\n    xor    %rdx, %rdx           # envp = NULL\n    xor    %rsi, %rsi           # argv = NULL\n    lea    binsh(%rip), %rdi    # rdi = \"/bin/sh\"\n    mov    $59, %rax            # syscall: execve\n    syscall\n\nbinsh:\n    .string \"/bin/sh\"",
