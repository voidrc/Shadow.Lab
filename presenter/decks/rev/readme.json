      "codeText": "file binary              # ELF, PE, Mach-O? 32/64-bit?\nstrings binary           # look for flags, URLs, keys, error messages\nstrings -n 6 binary      # min string length 6\nhexdump -C binary | head -20  # raw hex view\nobjdump -d binary        # disassemble all sections\nobjdump -d -M intel binary   # Intel syntax\nnm binary                # symbol table (if not stripped)\nreadelf -a binary        # ELF headers, sections, symbols",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
