    {
      "id": "7f3ed5ea-fa70-487b-8a78-64fb50d288a6",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Domain & IP Recon",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "codeText": "# WHOIS\nwhois example.com\nwhois 1.2.3.4\n\n# DNS records\nnslookup example.com\ndig example.com ANY +noall +answer\ndig @8.8.8.8 example.com MX\n\n# Reverse DNS\ndig -x 1.2.3.4\n\n# Subdomain discovery (passive)\nsubfinder -d example.com\namass enum -passive -d example.com\n# Online: https://dnsdumpster.com, https://crt.sh\n\n# Certificate transparency logs\ncurl \"https://crt.sh/?q=%.example.com&output=json\" | python3 -m json.tool\n\n# Shodan (indexed internet devices)\nshodan host 1.2.3.4         # requires API key\n# Online: https://shodan.io\n\n# Check historical DNS/WHOIS\n# https://securitytrails.com\n# https://viewdns.info",
      "codeLang": "bash",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
