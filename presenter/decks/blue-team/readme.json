      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "rule SuspiciousPowerShellDownload {\n    meta:\n        description = \"Detects PowerShell download cradles\"\n        author = \"Shadow.Lab\"\n    strings:\n        $s1 = \"DownloadString\" nocase\n        $s2 = \"IEX\" nocase\n        $s3 = \"WebClient\" nocase\n        $s4 = \"Invoke-Expression\" nocase\n    condition:\n        2 of ($s1, $s2, $s3, $s4)\n}\n\nrule SuspiciousImports {\n    meta:\n        description = \"PE with common injection imports\"\n    strings:\n        $a = \"VirtualAllocEx\"\n        $b = \"WriteProcessMemory\"\n        $c = \"CreateRemoteThread\"\n    condition:\n        all of them\n}",
      "codeLang": "yara",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showTable": false,
