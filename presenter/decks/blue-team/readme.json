    {
      "id": "8a7cb753-bbbc-4236-8eb0-dcd6dd30fb59",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
