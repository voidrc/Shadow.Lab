      "tableData": {
        "headers": [
          "Source",
          "What to Look For"
        ],
        "rows": [
          [
            "Windows Security Events",
            "4624/4625 (logon), 4688 (process creation), 4648 (explicit logon), 4698 (scheduled task)"
          ],
          [
            "Sysmon",
            "Process creation, network connections, file creation, registry changes"
          ],
          [
            "PowerShell logs",
            "Script block logging (4104), module logging"
          ],
          [
            "Windows Defender / EDR",
            "Detection events, quarantine actions"
          ],
          [
            "Firewall / proxy logs",
            "Allowed/denied connections, unusual outbound traffic"
          ],
          [
            "DNS logs",
            "Suspicious domains, high-frequency queries, DGA patterns"
          ],
          [
            "Web server logs",
            "Error spikes, unusual URIs, encoding anomalies"
          ],
          [
            "Authentication logs",
            "Failed logins, off-hours access, impossible travel"
          ]
        ]
      },
