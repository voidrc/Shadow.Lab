    {
      "id": "3e43f064-3bf4-4c78-a22c-4d0417a44e6a",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Hunting Hypothesis Framework",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "1. Threat Intel → \"APT29 uses beacon over HTTPS with JA3 fingerprint X\"\n2. TTP-based    → \"Hunt for evidence of Kerberoasting in the last 30 days\"\n3. Anomaly-based → \"Find hosts making DNS queries to 50+ unique domains/hour\"\n4. Situational  → \"Hunt after red team engagement to validate detections\"",
      "codeLang": "",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "313469b2-0b80-4760-b647-2d7492296121",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#030803 0%,#061206 100%)",
      "bgImage": "",
      "titleText": "Common Hunt Scenarios",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "#### Suspicious Scheduled Tasks\n#### Beaconing Detection (C2 Traffic)",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "index=windows EventCode=4698 OR EventCode=4702\n| rex field=TaskContent \"(?i)<Command>(?P<cmd>[^<]+)\"\n| where match(cmd, \"(?i)(powershell|wscript|mshta|regsvr32|certutil|bitsadmin)\")\n| table _time, host, user, TaskName, cmd",
      "codeLang": "splunk",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "slide-r"
    },
    {
      "id": "19ba50e1-d325-4c7f-be4c-901ec339e277",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Common Hunt Scenarios",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "#### Living-off-the-Land Execution",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "-- Identify hosts with very regular outbound connection intervals\nindex=network_traffic dest_port IN (80,443,8080)\n| bucket _time span=1h\n| stats count by _time, src_ip, dest_ip\n| eventstats avg(count) as avg_count, stdev(count) as stdev_count by src_ip, dest_ip\n| where stdev_count < 2   -- suspiciously regular = low stdev",
      "codeLang": "splunk",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "fc5687ec-33c9-494e-8945-c2c7f5ac4b0e",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Common Hunt Scenarios",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "#### Pass-the-Hash / Lateral Movement",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "index=sysmon EventCode=1\n| where match(Image, \"(?i)(certutil|mshta|regsvr32|wscript|cscript|msiexec|rundll32)\")\n  AND match(CommandLine, \"(?i)(http|ftp|\\\\\\\\|base64|decode)\")\n| table _time, host, user, Image, CommandLine, ParentImage, ParentCommandLine",
      "codeLang": "splunk",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "8af5ae89-aaf9-4dae-b2ca-a31df378d3b3",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Common Hunt Scenarios",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "#### DGA Domain Detection",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "`comment(\"Logon Type 3 with NTLM instead of Kerberos\")`\nindex=windows EventCode=4624 LogonType=3 AuthenticationPackageName=NTLM\n| stats count by src_ip, TargetUserName, host\n| where count > 5",
      "codeLang": "splunk",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": true,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
      "transition": "fade"
    },
    {
      "id": "04c58de9-7007-4f75-b32f-3a329c3e0e7b",
      "layout": "top",
      "bgType": "gradient",
      "bgColor": "#080b08",
      "bgGradient": "linear-gradient(160deg,#020602 0%,#040d04 100%)",
      "bgImage": "",
      "titleText": "Common Hunt Scenarios",
      "titleColor": "#00ff41",
      "titleSize": 48,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "`comment(\"High entropy domains in DNS queries\")`\nindex=dns query_type=A\n| eval domain_len=len(query)\n| eval char_freq=mvmap(split(query,\"\"), len(mvfilter(match(mvindex(split(query,\"\"),0), \".\")))),\n       entropy=-(sum(eval(f/domain_len * log(f/domain_len, 2))) over char_freq)\n| where entropy > 3.5 AND domain_len > 20\n| stats count by query, src_ip | sort -count",
      "codeLang": "splunk",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
