      "bgImage": "",
      "titleText": "Splunk Essentials",
      "titleColor": "#00ff41",
      "titleSize": 36,
      "subtitleText": "",
      "subtitleColor": "#2a6b3a",
      "bodyText": "",
      "bodyColor": "#7ab87a",
      "bodySize": 22,
      "bullets": [],
      "tableData": {
        "headers": [],
        "rows": []
      },
      "codeText": "`comment(\"Failed logins\")`\nindex=windows EventCode=4625 | stats count by src_ip, user | sort -count\n\n`comment(\"Process creation - Sysmon Event 1\")`\nindex=sysmon EventCode=1 | table _time, host, user, Image, CommandLine, ParentImage\n\n`comment(\"PowerShell script block logging\")`\nindex=windows EventCode=4104 | search ScriptBlockText=\"*Invoke-*\" OR ScriptBlockText=\"*iex*\"\n\n`comment(\"Network connections to rare external IPs\")`\nindex=sysmon EventCode=3 DestinationIp!=\"10.*\" DestinationIp!=\"192.168.*\" DestinationIp!=\"172.16.*\"\n| stats count by DestinationIp, Image | sort -count\n\n`comment(\"Lateral movement via PsExec\")`\nindex=windows EventCode=7045 ServiceName=\"PSEXESVC\" | table _time, host, ServiceFileName\n\n`comment(\"DCSync detection\")`\nindex=windows EventCode=4662 OperationType=\"%%14674\" ObjectDN=\"*DC=*\"\n| where match(Properties, \"(?i)1131f6ad|1131f6aa\")",
      "codeLang": "splunk",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
      "showTable": false,
      "showCode": true,
      "showImage": false,
      "textAlign": "left",
      "fontFamily": "'Courier New', 'Fira Mono', monospace",
