        "headers": [],
        "rows": []
      },
      "codeText": "// Process injection\nsequence by host.name\n  [process where process.name == \"powershell.exe\"]\n  [network where destination.port in (443, 80, 8080) and not destination.ip in (\"10.0.0.0/8\")]\n\n// Credential dumping via LSASS\nprocess where event.type == \"start\"\n  and process.name in (\"procdump.exe\", \"procdump64.exe\", \"rundll32.exe\")\n  and process.args : \"*lsass*\"",
      "codeLang": "eql",
      "imageUrl": "",
      "showTitle": true,
      "showSubtitle": false,
      "showBody": false,
      "showBullets": false,
